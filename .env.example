NODE_ENV=development
PORT=3000
TRUST_PROXY=1

# External search provider
SERPAPI_KEY=

# Browser origins allowed by CORS and origin guard
FRONTEND_URL=https://mais-justica.vercel.app
ALLOWED_ORIGINS=https://mais-justica.vercel.app,http://localhost:3000,http://localhost:5173,http://localhost:5500,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5500
ALLOWED_ORIGIN_PATTERNS=^https://mais-justica(?:-[a-z0-9-]+)?\.vercel\.app$
ALLOW_REQUESTS_WITHOUT_ORIGIN=true
BLOCK_UNKNOWN_ORIGIN=false

# Optional API protection for paid plans or server-to-server clients
REQUIRE_API_KEY=false
API_KEYS=
REQUIRE_REQUEST_SIGNATURE=false
REQUEST_SIGNATURE_SECRET=
SIGNATURE_MAX_AGE_SECONDS=300

# Request limits and timeouts
JSON_BODY_LIMIT=32kb
URLENCODED_BODY_LIMIT=16kb
REQUEST_TIMEOUT_MS=45000
EXTERNAL_TIMEOUT_MS=12000
SCAN_DELAY_MS=800
MIN_CONFIDENCE=85

# Abuse controls
GENERAL_RATE_LIMIT_WINDOW_MS=900000
GENERAL_RATE_LIMIT_MAX=300
API_RATE_LIMIT_MAX=120
SCAN_RATE_LIMIT_MAX=8
BRUTE_FORCE_RATE_LIMIT_MAX=12
SLOWDOWN_AFTER=2
SLOWDOWN_MAX_DELAY_MS=4000

# CSP rollout
CSP_REPORT_ONLY=false
CSP_REPORT_URI=

# Contact email
EMAIL_USER=
EMAIL_PASS=
CONTACT_TO_EMAIL=maisjustica.suporte@gmail.com
